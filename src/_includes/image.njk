---
layout: "base.njk"
---

<div class="box">
   <h1>{{ item.title }}</h1>
   {% if item.date %}
     <label>Published: {{ item.date }}</label>
   {% endif %}
   {% if item.image %}
    <figure>
        <img src="/gallery/{{ item.image }}" alt="{{ item.title }}" />
        {% if item.caption %}
          <figcaption>{{ item.caption }}</figcaption>
        {% endif %}
    </figure>
   {% endif %}
</div>

<div class="postnav">
  {% if pagination.pageNumber > 0 %}
    <a class="button" href="{{ pagination.hrefs[pagination.pageNumber - 1] }}">&#x1F870; Older</a>
  {% endif %}
  {% if pagination.pageNumber < pagination.pages.length - 1 %}
    <a class="button" href="{{ pagination.hrefs[pagination.pageNumber + 1] }}">Newer &#x1F872;</a>
  {% endif %}
</div>